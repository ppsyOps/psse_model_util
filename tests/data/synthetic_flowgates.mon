BUSNAMES

MONITOR FLOWGATE 1001  'synthetic FG 1001'
         BRANCH FROM BUS 'NUCPLNT     500.00' TO BUS 'MID500      500.00' CKT 1
 CONTINGENCY 1001
    OPEN BRANCH FROM BUS 'NUCPLNT     500.00' TO BUS 'MID500      500.00' CKT 2
 END
    CA SYN SYN
    SC SCA
    TP SCA SCA
END

MONITOR FLOWGATE 1002  'synthetic FG 1002'
         BRANCH FROM BUS 'MID500      500.00' TO BUS 'EAST500     500.00' CKT 1
 CONTINGENCY 1002
    OPEN BRANCH FROM BUS 'MID230      230.00' TO BUS 'DOWNTN      230.00' CKT 2
 END
    CA SYN SYN
    SC SCA
    TP SCA SCA
END

MONITOR FLOWGATE 1003  'synthetic FG 1003 gen contingency'
         BRANCH FROM BUS 'NUCPLNT     500.00' TO BUS 'MID500      500.00' CKT 1
 CONTINGENCY 1003
    REMOVE MACHINE 1 FROM BUS 'NUC-A       21.60 '
 END
    CA SYN SYN
    SC SCA
    TP SCA SCA
END

MONITOR FLOWGATE 9001  'synthetic SCB flowgate'
         BRANCH FROM BUS 'COGEN-3     500.00' TO BUS 'LOADER      230.00' CKT 1
 CONTINGENCY 9001
    OPEN BRANCH FROM BUS 'COGEN-3     500.00' TO BUS 'LOADER      230.00' CKT 1
 END
    CA SYN SYN
    SC SCB
    TP SCB SCB
END
